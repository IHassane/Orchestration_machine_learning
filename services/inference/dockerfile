FROM python:3.10-slim

WORKDIR /app

# Installation des dépendances système légères
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copie des dépendances
COPY requirements.txt .

# Force globalement l'index CPU pour torch
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir torch==2.2.1 torchvision==0.17.1 --index-url https://download.pytorch.org/whl/cpu

# On installe le reste (FastAPI, Uvicorn, etc.)
RUN pip install --no-cache-dir -r requirements.txt

# --- MODIFICATION ICI ---
# Au lieu de juste faire un mkdir vide, on copie le contenu de ton dossier local
# Assure-toi que tes fichiers .pt sont bien dans services/inference/models/ sur ton Mac
COPY models/ ./models/

# Copie de l'application
COPY app.py .

EXPOSE 5001

CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "5001", "--workers", "2"]